# QuantDash local environment template.
# Copy to .env.local and fill local/private values before running `task dev`.

# Next.js BFF -> FastAPI backend
MARKET_API_BASE_URL=http://127.0.0.1:8000

# Backend storage
POSTGRES_DSN=postgresql://quantdash:quantdash@127.0.0.1:5432/quantdash
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SECONDS=300
QUOTE_CACHE_TTL_SECONDS=3
INDEX_CACHE_TTL_SECONDS=5
QUOTE_BATCH_MAX_SYMBOLS=50
QUOTE_PROVIDER_MAX_WORKERS=3

# External data providers
# Required for Tushare-backed stock profiles, announcements, financial metrics,
# and historical index constituents used by Universe Center.
TUSHARE_TOKEN=

# News Center reads the SQLite snapshots uploaded by news-collector to R2.
NEWS_R2_ENDPOINT_URL=
NEWS_R2_BUCKET_NAME=
NEWS_R2_ACCESS_KEY_ID=
NEWS_R2_SECRET_ACCESS_KEY=
NEWS_R2_REGION=
NEWS_R2_PREFIX=news
NEWS_R2_CACHE_TTL_SECONDS=300
HOT_NEWS_SOURCES=cls-hot,wallstreetcn-hot,ifeng

# Optional AI analysis for News Center. Keep disabled until credentials are set.
AI_ANALYSIS_ENABLED=false
AI_ANALYSIS_TIMELINE_PATH=backend/config/news_ai_timeline.yaml
AI_ANALYSIS_MAX_NEWS=150
AI_MODEL=deepseek/deepseek-v4-flash
AI_API_KEY=
AI_API_BASE=
AI_TIMEOUT_SECONDS=120
AI_TEMPERATURE=1.0
AI_MAX_TOKENS=5000
AI_NUM_RETRIES=1

# Scheduler
SCHEDULER_ENABLED=false
HOT_KEYWORDS_REFRESH_MINUTES=30
STOCK_PROFILE_REFRESH_HOURS=24
TRADE_CALENDAR_REFRESH_HOURS=24
DAILY_BARS_CRON_HOUR=16
FINANCIALS_CRON_HOUR=20
DAILY_REFRESH_WATCHLIST=600519,300750,688981,000001,601318
